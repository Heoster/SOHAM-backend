{
  "name": "soham-backend-server",
  "version": "1.0.0",
  "description": "SOHAM AI Backend Server — Everything intelligent happens here",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register server.ts",
    "build": "tsc",
    "postinstall": "npm run build",
    "start": "node -r tsconfig-paths/register dist/server.js",
    "start:ts": "ts-node -r tsconfig-paths/register server.ts",
    "setup": "node setup.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "health": "node -r tsconfig-paths/register dist/server.js --health",
    "prod": "NODE_ENV=production node -r tsconfig-paths/register dist/server.js"
  },
  "dependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "together-ai": "0.39.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
