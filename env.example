# SOHAM Backend Server - Environment Variables
# Copy this to .env and fill in your values

# ── AI Providers ──────────────────────────────────────────────────────────────
# REQUIRED: At least GROQ_API_KEY must be set
GROQ_API_KEY=                        # https://console.groq.com/keys
GOOGLE_API_KEY=                      # https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=                   # Same as GOOGLE_API_KEY (for embeddings)
CEREBRAS_API_KEY=                    # https://cloud.cerebras.ai
HUGGINGFACE_API_KEY=                 # https://huggingface.co/settings/tokens
OPENROUTER_API_KEY=                  # https://openrouter.ai/keys

# ── Image Generation ──────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=               # Cloudflare dashboard sidebar
CLOUDFLARE_AI_API_TOKEN=             # Workers AI:Edit permission token
CLOUDFLARE_AI_GATEWAY_ID=            # Optional: AI Gateway slug for caching

# ── Memory / Database ─────────────────────────────────────────────────────────
SUPABASE_URL=                        # https://supabase.com/dashboard
SUPABASE_ANON_KEY=                   # Supabase project anon key
SUPABASE_SERVICE_ROLE_KEY=           # Supabase service role key (for server)
UPSTASH_VECTOR_REST_URL=             # https://console.upstash.com/vector
UPSTASH_VECTOR_REST_TOKEN=           # Upstash Vector REST token

# ── Search APIs ───────────────────────────────────────────────────────────────
# PRIMARY (recommended — best quality)
TAVILY_API_KEY=                      # https://app.tavily.com  (real-time web search)
FIRECRAWL_API_KEY=                   # https://www.firecrawl.dev  (deep content extraction)

# DOMAIN-SPECIFIC (optional)
GNEWS_API_KEY=                       # https://gnews.io (news articles)
CRICAPI_KEY=                         # https://cricapi.com (live cricket / sports)
ALPHA_VANTAGE_API_KEY=               # https://alphavantage.co (stock prices)

# FREE FALLBACKS (no key needed — always active)
# Wikipedia, DuckDuckGo, Open-Meteo (weather), CoinGecko (crypto)

# ── Server Config ─────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
SOHAM_API_KEY=soham-secret-key-2025   # Shared secret between frontend and backend
